#include <stdio.h>
#include <omp.h>
#define SIZE 1000000

int main() {
int arr[SIZE];
long long sum = 0;
for (int i = 0; i < SIZE; i++) arr[i] = i + 1;

double start_time = omp_get_wtime();
#pragma omp parallel for reduction(+:sum)
for (int i = 0; i < SIZE; i++) {
sum += arr[i];
}

double end_time = omp_get_wtime();
printf("Sum: %lld\n", sum);
printf("Time taken: %f seconds\n", end_time - start_time);
return 0;
}


#include <stdio.h>
#include <stdlib.h>
#include <omp.h>


int main() {
    int V1[1000], V2[1000];
    long long serial_sum = 0, parallel_sum = 0;
    double start, end;

    for (int i = 0; i < 1000; i++) {
        V1[i] = rand() % 100 + 1;
        V2[i] = rand() % 100 + 1;
    }

    start = omp_get_wtime();
    for (int i = 0; i < 1000; i++) {
        serial_sum += V1[i] * V2[i];
    }
    end = omp_get_wtime();
    printf("Serial Dot Product = %lld\n", serial_sum);
    printf("Serial Time = %f seconds\n\n", end - start);


    start = omp_get_wtime();
    #pragma omp parallel for reduction(+:parallel_sum)
    for (int i = 0; i < 1000; i++) {
        parallel_sum += V1[i] * V2[i];
    }
    end = omp_get_wtime();
    printf("Parallel Dot Product = %lld\n", parallel_sum);
    printf("Parallel Time = %f seconds\n\n", end - start);

	start = omp_get_wtime();
	#pragma omp single
        {
        for (int i = 0; i < 1000; i++) 
        {
        serial_sum += V1[i] * V2[i];
    	}
        }
    end = omp_get_wtime();
    printf("Single Thread Dot Product = %lld\n", parallel_sum);
    printf("Single Thread Time = %f seconds\n", end - start);

    return 0;
}



