#include <mpi.h>

int main(int argc, char *argv[]) {

    int rank, size;
    int token;

    MPI_Init(&argc, &argv);

    MPI_Comm_rank(MPI_COMM_WORLD, &rank);
    MPI_Comm_size(MPI_COMM_WORLD, &size);

    int next = (rank + 1) % size;
    int prev = (rank - 1 + size) % size;

    token = rank;

    MPI_Sendrecv(&token, 1, MPI_INT, next, 0,
                 &token, 1, MPI_INT, prev, 0,
                 MPI_COMM_WORLD, MPI_STATUS_IGNORE);

    printf("P%d received %d\n", rank, token);

    MPI_Finalize();
}










matrix multiplication
#include <stdio.h>
#include <stdlib.h>
#include <mpi.h>

#define N 4

int main(int argc, char *argv[])
{
    int rank, size;

    int A[N][N], B[N][N], C[N][N];

    int localA[N];
    int localC[N];

    MPI_Init(&argc, &argv);

    MPI_Comm_rank(MPI_COMM_WORLD, &rank);
    MPI_Comm_size(MPI_COMM_WORLD, &size);

    // Number of processes must equal N
    if(size != N)
    {
        if(rank == 0)
            printf("Run with %d processes\n", N);

        MPI_Finalize();
        return 0;
    }

    // Initialize matrices at root
    if(rank == 0)
    {
        printf("Matrix A:\n");

        for(int i=0; i<N; i++)
        {
            for(int j=0; j<N; j++)
            {
                A[i][j] = i + j;

                printf("%d ", A[i][j]);
            }

            printf("\n");
        }

        printf("\nMatrix B:\n");

        for(int i=0; i<N; i++)
        {
            for(int j=0; j<N; j++)
            {
                B[i][j] = i * j;

                printf("%d ", B[i][j]);
            }

            printf("\n");
        }
    }

    // Scatter rows of A
    MPI_Scatter(A, N, MPI_INT,
                localA, N, MPI_INT,
                0, MPI_COMM_WORLD);

    // Broadcast full matrix B
    MPI_Bcast(B, N*N, MPI_INT,
              0, MPI_COMM_WORLD);

    // Local multiplication
    for(int j=0; j<N; j++)
    {
        localC[j] = 0;

        for(int k=0; k<N; k++)
        {
            localC[j] += localA[k] * B[k][j];
        }
    }

    // Gather results
    MPI_Gather(localC, N, MPI_INT,
               C, N, MPI_INT,
               0, MPI_COMM_WORLD);

    // Print result
    if(rank == 0)
    {
        printf("\nResult Matrix C:\n");

        for(int i=0; i<N; i++)
        {
            for(int j=0; j<N; j++)
            {
                printf("%d ", C[i][j]);
            }

            printf("\n");
        }
    }

    MPI_Finalize();

    return 0;
}













ring latency
#include <stdio.h>
#include <stdlib.h>
#include <mpi.h>

#define NUMBER_OF_TESTS 100

int main(int argc, char *argv[])
{
    int rank, size;
    int tag = 0;

    MPI_Init(&argc, &argv);

    MPI_Comm_rank(MPI_COMM_WORLD, &rank);
    MPI_Comm_size(MPI_COMM_WORLD, &size);

    int message_sizes[] = {1, 10, 100, 1000, 10000};
    int num_sizes = 5;

    for(int s = 0; s < num_sizes; s++)
    {
        int msg_size = message_sizes[s];

        double *buffer = (double *)malloc(msg_size * sizeof(double));

        double total_time = 0.0;

        for(int test = 0; test < NUMBER_OF_TESTS; test++)
        {
            MPI_Barrier(MPI_COMM_WORLD);

            double start, end;

            int next = (rank + 1) % size;
            int prev = (rank - 1 + size) % size;

            if(rank == 0)
            {
                start = MPI_Wtime();

                // Send to next process
                MPI_Send(buffer, msg_size, MPI_DOUBLE,
                         next, tag, MPI_COMM_WORLD);

                // Receive from previous process
                MPI_Recv(buffer, msg_size, MPI_DOUBLE,
                         prev, tag, MPI_COMM_WORLD,
                         MPI_STATUS_IGNORE);

                end = MPI_Wtime();

                total_time += (end - start);
            }
            else
            {
                // Receive from previous process
                MPI_Recv(buffer, msg_size, MPI_DOUBLE,
                         prev, tag, MPI_COMM_WORLD,
                         MPI_STATUS_IGNORE);

                // Send to next process
                MPI_Send(buffer, msg_size, MPI_DOUBLE,
                         next, tag, MPI_COMM_WORLD);
            }
        }

        if(rank == 0)
        {
            double avg_latency =
                (total_time / NUMBER_OF_TESTS) * 1000.0;

            printf("Message Size = %d doubles\t",
                   msg_size);

            printf("Avg Latency = %f ms\n",
                   avg_latency);
        }

        free(buffer);
    }

    MPI_Finalize();

    return 0;
}









#include <stdio.h>
#include <stdlib.h>
#include <mpi.h>

int main(int argc, char *argv[])
{
    int rank, size;

    MPI_Init(&argc, &argv);

    MPI_Comm_rank(MPI_COMM_WORLD, &rank);
    MPI_Comm_size(MPI_COMM_WORLD, &size);

    // Must run with exactly 4 processes
    if(size != 4)
    {
        if(rank == 0)
            printf("Run with exactly 4 processes\n");

        MPI_Finalize();
        return 0;
    }

    int n = 2;

    // Broadcast variable
    MPI_Barrier(MPI_COMM_WORLD);

    MPI_Bcast(&n, 1, MPI_INT,
              0, MPI_COMM_WORLD);

    int sendbuf[8];
    int recvbuf[2];
    int gatherbuf[8];

    // Initialize array at root
    if(rank == 0)
    {
        printf("Original Array:\n");

        for(int i = 0; i < 4 * n; i++)
        {
            sendbuf[i] = i + 1;

            printf("%d ", sendbuf[i]);
        }

        printf("\n");
    }

    // Synchronize before scatter
    MPI_Barrier(MPI_COMM_WORLD);

    // Scatter n integers to each process
    MPI_Scatter(sendbuf, n, MPI_INT,
                recvbuf, n, MPI_INT,
                0, MPI_COMM_WORLD);

    printf("Process %d received: ",
           rank);

    for(int i = 0; i < n; i++)
    {
        printf("%d ", recvbuf[i]);
    }

    printf("\n");

    // Local computation
    for(int i = 0; i < n; i++)
    {
        recvbuf[i] *= 2;
    }

    printf("Process %d processed: ",
           rank);

    for(int i = 0; i < n; i++)
    {
        printf("%d ", recvbuf[i]);
    }

    printf("\n");

    // Synchronize before gather
    MPI_Barrier(MPI_COMM_WORLD);

    // Gather results back to root
    MPI_Gather(recvbuf, n, MPI_INT,
               gatherbuf, n, MPI_INT,
               0, MPI_COMM_WORLD);

    // Print gathered array
    if(rank == 0)
    {
        printf("\nFinal Gathered Array:\n");

        for(int i = 0; i < 4 * n; i++)
        {
            printf("%d ", gatherbuf[i]);
        }

        printf("\n");
    }

    MPI_Finalize();

    return 0;
}


























