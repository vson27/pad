Isend Irecv
#include <stdio.h>
#include <mpi.h>

int main(int argc, char *argv[]) {

    int rank;
    int data = 123;
    MPI_Request request;

    MPI_Init(&argc, &argv);

    MPI_Comm_rank(MPI_COMM_WORLD, &rank);

    if(rank == 0) {

        MPI_Isend(&data, 1, MPI_INT,
                  1, 0,
                  MPI_COMM_WORLD,
                  &request);

        MPI_Wait(&request, MPI_STATUS_IGNORE);
    }

    else if(rank == 1) {

        MPI_Irecv(&data, 1, MPI_INT,
                  0, 0,
                  MPI_COMM_WORLD,
                  &request);

        MPI_Wait(&request, MPI_STATUS_IGNORE);

        printf("Received %d\n", data);
    }

    MPI_Finalize();
}









