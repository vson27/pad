1. MPI_Init
------------
Initializes MPI environment

Syntax:
MPI_Init(&argc, &argv);


2. MPI_Finalize
----------------
Terminates MPI environment

Syntax:
MPI_Finalize();


3. MPI_Comm_rank
-----------------
Gets rank (process ID)

Syntax:
MPI_Comm_rank(MPI_COMM_WORLD, &rank);


4. MPI_Comm_size
-----------------
Gets total number of processes

Syntax:
MPI_Comm_size(MPI_COMM_WORLD, &size);


5. MPI_Send
------------
Blocking send

Syntax:
MPI_Send(buffer,
         count,
         datatype,
         destination_rank,
         tag,
         communicator);

Example:
MPI_Send(&x, 1, MPI_INT, 1, 0, MPI_COMM_WORLD);


6. MPI_Recv
------------
Blocking receive

Syntax:
MPI_Recv(buffer,
         count,
         datatype,
         source_rank,
         tag,
         communicator,
         &status);

Example:
MPI_Recv(&x, 1, MPI_INT, 0, 0,
         MPI_COMM_WORLD, &status);


7. MPI_Isend
-------------
Non-blocking send

Syntax:
MPI_Isend(buffer,
          count,
          datatype,
          destination,
          tag,
          communicator,
          &request);


8. MPI_Irecv
-------------
Non-blocking receive

Syntax:
MPI_Irecv(buffer,
          count,
          datatype,
          source,
          tag,
          communicator,
          &request);


9. MPI_Wait
------------
Wait for non-blocking operation

Syntax:
MPI_Wait(&request, &status);


10. MPI_Bcast
--------------
Broadcast data from root to all

Syntax:
MPI_Bcast(buffer,
          count,
          datatype,
          root,
          communicator);

Example:
MPI_Bcast(&n, 1, MPI_INT, 0, MPI_COMM_WORLD);


11. MPI_Scatter
----------------
Distribute chunks of data

Syntax:
MPI_Scatter(sendbuf,
            sendcount,
            sendtype,
            recvbuf,
            recvcount,
            recvtype,
            root,
            communicator);


12. MPI_Gather
---------------
Collect data to root

Syntax:
MPI_Gather(sendbuf,
           sendcount,
           sendtype,
           recvbuf,
           recvcount,
           recvtype,
           root,
           communicator);


13. MPI_Reduce
---------------
Reduce values to root

Syntax:
MPI_Reduce(sendbuf,
           recvbuf,
           count,
           datatype,
           operation,
           root,
           communicator);

Operations:
MPI_SUM
MPI_MAX
MPI_MIN
MPI_PROD


14. MPI_Allreduce
------------------
Reduce and distribute result to all

Syntax:
MPI_Allreduce(sendbuf,
              recvbuf,
              count,
              datatype,
              operation,
              communicator);


15. MPI_Barrier
----------------
Synchronize all processes

Syntax:
MPI_Barrier(MPI_COMM_WORLD);


16. MPI_Sendrecv
-----------------
Send and receive simultaneously

Syntax:
MPI_Sendrecv(sendbuf,
             sendcount,
             sendtype,
             dest,
             sendtag,
             recvbuf,
             recvcount,
             recvtype,
             source,
             recvtag,
             communicator,
             &status);


17. MPI_Wtime
--------------
Returns elapsed wall-clock time

Syntax:
double t;
t = MPI_Wtime();


18. MPI_Status
---------------
Stores receive information

Syntax:
MPI_Status status;


19. MPI_Request
----------------
Used for non-blocking communication

Syntax:
MPI_Request request;


